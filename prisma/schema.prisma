generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  positionLots  PositionLot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ───────────────────────────────────────────────────

model Trade {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol         String
  symbolName     String?
  market         String          // "TWSE" | "TPEX"
  side           String          // "BUY" | "SELL"
  tradeDate      DateTime
  settlementDate DateTime?

  lotType        String          // "ROUND" | "ODD"
  lots           Int?
  shares         Int
  price          Float

  commission     Float
  transactionTax Float
  totalFees      Float
  grossAmount    Float
  netAmount      Float

  realizedPnL    Float?
  isETF          Boolean  @default(false)

  stopLoss       Float?
  takeProfit     Float?
  notes          String?
  tags           String?

  positionLots   PositionLot[]

  @@index([userId])
  @@index([symbol])
  @@index([tradeDate])
}

model PositionLot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  market       String
  lotType      String
  openTradeId  String
  openTrade    Trade    @relation(fields: [openTradeId], references: [id], onDelete: Cascade)
  openDate     DateTime
  shares       Int
  costPerShare Float
  isOpen       Boolean  @default(true)

  @@index([userId])
  @@index([symbol, isOpen])
}
