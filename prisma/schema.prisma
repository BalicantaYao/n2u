generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  positionLots  PositionLot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trade {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  symbol         String
  symbolName     String?
  market         String
  side           String
  tradeDate      DateTime
  settlementDate DateTime?

  lotType        String
  lots           Int?
  shares         Int
  price          Float

  commission     Float
  transactionTax Float
  totalFees      Float
  grossAmount    Float
  netAmount      Float

  realizedPnL    Float?
  isETF          Boolean  @default(false)

  stopLoss       Float?
  notes          String?
  tags           String?

  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  positionLots   PositionLot[]

  @@index([symbol])
  @@index([tradeDate])
  @@index([userId])
}

model PositionLot {
  id           String   @id @default(cuid())
  symbol       String
  market       String
  lotType      String
  openTradeId  String
  openTrade    Trade    @relation(fields: [openTradeId], references: [id], onDelete: Cascade)
  openDate     DateTime
  shares       Int
  costPerShare Float
  isOpen       Boolean  @default(true)

  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  @@index([symbol, isOpen])
  @@index([userId])
}
